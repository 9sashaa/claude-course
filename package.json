{
  "name": "expense-tracker",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:web": "npm run dev --workspace @expense-tracker/frontend",
    "dev:api": "npm run dev --workspace @expense-tracker/backend",
    "db:generate": "npm run prisma:generate --workspace @expense-tracker/backend",
    "db:migrate": "npm run prisma:migrate --workspace @expense-tracker/backend",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
